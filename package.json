{
  "name": "hush",
  "version": "0.11.0",
  "description": "Offline voice-to-text for macOS, Windows, and Linux.",
  "type": "module",
  "scripts": {
    "dev": "HUSH_MOCK=1 vite dev",
    "dev:tauri": "vite dev",
    "dev:e2e": "HUSH_E2E=1 vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run src",
    "test:unit:watch": "vitest src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:tauri": "wdio run wdio.conf.ts",
    "test:uxwalk": "playwright test tests/e2e/zz-uxwalk.spec.ts --reporter=list && echo 'Screenshots → /tmp/hush-uxwalk-shots/'",
    "test:screenshots": "playwright test tests/e2e/zz-screenshots.spec.ts --reporter=list && echo 'Screenshots → tmp/uxwalk/light/  and  tmp/uxwalk/dark/'",
    "dev-cleanup": "bash scripts/dev-cleanup.sh",
    "dev-reset": "bash scripts/dev-reset.sh",
    "dev-reset:keep": "bash scripts/dev-reset.sh --keep-app-state",
    "tauri": "tauri",
    "tauri:bundle": "bash scripts/tauri-bundle-macos.sh",
    "tauri:dmg": "bash scripts/tauri-dmg-macos.sh",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.6",
    "webdriverio": "^9.0.0"
  }
}
