{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hush",
  "version": "0.10.0",
  "identifier": "io.github.khawkins98.hush",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Hush",
        "width": 800,
        "height": 600,
        "minWidth": 720,
        "minHeight": 400,
        "maximizable": false
      },
      {
        "label": "hud",
        "title": "Hush \u2014 Recording",
        "url": "/hud",
        "width": 290,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": true
      },
      {
        "label": "menu-bar",
        "title": "Hush",
        "url": "/menu-bar",
        "width": 320,
        "height": 220,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": true,
        "visible": false,
        "acceptFirstMouse": true
      },
      {
        "label": "debug",
        "title": "Hush \u2014 Debug Console",
        "url": "/debug",
        "width": 760,
        "height": 520,
        "minWidth": 540,
        "minHeight": 320,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost tauri: https://api.github.com; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Permissions-Policy": "microphone=(), camera=(), geolocation=(), payment=()"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 700
        },
        "appPosition": {
          "x": 165,
          "y": 185
        },
        "applicationFolderPosition": {
          "x": 495,
          "y": 185
        }
      }
    },
    "resources": [
      "resources/hush-audio-tap-capture"
    ]
  }
}
