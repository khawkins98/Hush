{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hush",
  "version": "0.1.0",
  "identifier": "com.khawkins.hush",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Hush",
        "width": 800,
        "height": 600
      },
      {
        "label": "hud",
        "title": "Hush — Recording",
        "url": "/hud",
        "width": 250,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": false
      },
      {
        "label": "settings",
        "title": "Hush Settings",
        "url": "/settings",
        "width": 720,
        "height": 520,
        "minWidth": 560,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
