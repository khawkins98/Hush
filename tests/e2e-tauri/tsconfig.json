{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@wdio/globals/types", "@wdio/mocha-framework", "expect-webdriverio"]
  },
  "include": ["specs/**/*.ts", "../../wdio.conf.ts"]
}
